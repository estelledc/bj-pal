{
  "schema_version": 1,
  "name": "bj-pal-constraint-ledger-synthetic-v1",
  "classification": "synthetic",
  "label_basis": "Hand-authored Mandarin planning phrases derived from the reproduced default-drift failure and supported BJ-Pal preference fields. Labels test exact typed preservation, explicit conflicts, negative phrases, rewrite coverage, and serialization idempotency.",
  "cases": [
    {
      "case_id": "reproduced-multi-constraint-drift",
      "user_input": "周六下午三点，两个人在三里屯玩三小时，人均预算100元，不吃辣",
      "expected": {
        "text_constraints": {
          "preferences.party_size": 2,
          "preferences.diet_flags": ["no_spicy"],
          "preferences.budget_per_person": 100,
          "preferences.target_start": "15:00",
          "preferences.duration_hours": 3
        },
        "effective_constraints": {
          "preferences.party_size": 2,
          "preferences.diet_flags": ["no_spicy"],
          "preferences.budget_per_person": 100,
          "preferences.target_start": "15:00",
          "preferences.duration_hours": 3
        },
        "rewrite_contains": ["人数=2", "忌口=no_spicy", "人均预算=100元", "开始=15:00", "时长=3小时"]
      }
    },
    {
