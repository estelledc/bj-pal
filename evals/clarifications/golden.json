      "request": {
        "user_input": "三里屯还是国贸，选一个安排下午行程",
        "provided_fields": ["user_input"]
      },
      "expected_code": "multiple_area_candidates",
      "expected_field": "area_anchor",
      "expected_option_ids": ["use_area_1", "use_area_2", "use_area_3"],
      "selected_option_id": "use_area_2",
      "expected_effective_value": "国贸-CBD片区"
    },
    {
      "case_id": "relative-home-provide-area",
      "delivery": "sync",
      "request": {
        "user_input": "别离家太远，带娃玩四小时",
        "provided_fields": ["user_input"]
      },
      "expected_code": "missing_location_reference",
      "expected_field": "area_anchor",
      "expected_option_ids": ["use_area_1", "provide_area"],
      "selected_option_id": "provide_area",
      "answer": "望京片区",
      "expected_effective_value": "望京片区"
    },
    {
      "case_id": "previous-plan-revise-request",
      "delivery": "sync",
      "request": {
        "user_input": "按之前的方案继续安排",
        "provided_fields": ["user_input"]
      },
      "expected_code": "unresolved_plan_reference",
      "expected_field": "user_input",
      "expected_option_ids": ["provide_revised_request", "restart_with_area"],
      "selected_option_id": "provide_revised_request",
      "answer": "周六下午去望京逛商场并吃晚饭",
      "expected_effective_value": "周六下午去望京逛商场并吃晚饭"
    },
    {
      "case_id": "ordinal-selection-restart",
      "delivery": "sync",
      "request": {
        "user_input": "第二个方案吧",
        "provided_fields": ["user_input"]
      },
      "expected_code": "unresolved_selection_reference",
      "expected_field": "user_input",
      "expected_option_ids": ["provide_revised_request", "restart_with_area"],
      "selected_option_id": "restart_with_area",
      "expected_effective_value": "在五道营-雍和宫片区重新生成本次短时活动方案"
