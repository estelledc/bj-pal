{
  "schema_version": 1,
  "name": "bj-pal-clarification-continuation-synthetic-v1",
  "classification": "synthetic",
  "label_basis": "Hand-authored execution-critical ambiguities spanning typed constraint conflicts, area conflicts, relative locations, and missing conversation context. Labels cover deterministic preflight continuation only.",
  "cases": [
    {
      "case_id": "party-use-text",
      "delivery": "sync",
      "request": {
        "user_input": "下午三点，两个人在三里屯玩三小时",
        "preferences": {"party_size": 4, "target_start": "15:00", "duration_hours": 3},
        "provided_fields": ["user_input", "preferences.party_size", "preferences.target_start", "preferences.duration_hours"]
      },
      "expected_code": "constraint_conflict",
      "expected_field": "preferences.party_size",
      "expected_option_ids": ["use_text_value", "use_structured_value"],
      "selected_option_id": "use_text_value",
      "expected_effective_value": 2
    },
    {
      "case_id": "party-use-structured",
      "delivery": "job",
      "job_policy": {"deadline_seconds": 45},
      "request": {
        "user_input": "下午三点，两个人在三里屯玩三小时",
        "preferences": {"party_size": 4, "target_start": "15:00", "duration_hours": 3},
        "provided_fields": ["user_input", "preferences.party_size", "preferences.target_start", "preferences.duration_hours"]
      },
      "expected_code": "constraint_conflict",
      "expected_field": "preferences.party_size",
      "expected_option_ids": ["use_text_value", "use_structured_value"],
      "selected_option_id": "use_structured_value",
      "expected_effective_value": 4
    },
    {
      "case_id": "budget-use-text",
