      "request": {
        "user_input": "周六下午去三里屯逛逛",
        "area_anchor": "五道营-雍和宫片区",
        "provided_fields": ["user_input", "area_anchor"]
      },
      "expected_code": "conflicting_area_anchor",
      "expected_field": "area_anchor",
      "expected_option_ids": ["use_area_1", "use_area_2", "provide_area"],
