# Copy this file to the project root as `.env`, then fill in one backend.
# Do not commit real API keys.

# Option A: LongCat
BJ_PAL_LLM=longcat
LONGCAT_API_KEY=replace_with_your_longcat_key
LONGCAT_BASE_URL=https://api.longcat.chat/anthropic
BJ_PAL_LONGCAT_MODEL=LongCat-2.0-Preview
BJ_PAL_LONGCAT_MAX_TOKENS=8192

# Option B: DPSK / DeepSeek
# BJ_PAL_LLM=dpsk
# DPSK_API_KEY=replace_with_your_dpsk_key
# DPSK_BASE_URL=replace_with_your_dpsk_base_url
# DPSK_MODEL=replace_with_your_dpsk_model
# DPSK_MAX_TOKENS=8192

# Option C: Anthropic
# BJ_PAL_LLM=anthropic
# ANTHROPIC_API_KEY=replace_with_your_anthropic_key
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Option D: offline demo, no API key needed
# BJ_PAL_LLM=mock
